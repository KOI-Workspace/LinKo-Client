{
  "designSystem": {
    "meta": {
      "name": "Mintlify-Inspired Custom Design System",
      "version": "1.0.0",
      "basedOn": "Mintlify dashboard UI (2026)",
      "customizations": [
        "Replaced Mintlify mint-green primary with purple #8B5CF6",
        "Added pink #EC4899 as secondary accent",
        "Replaced default sans-serif with Pretendard"
      ]
    },

    "colorPalette": {
      "primary": {
        "base": "#8B5CF6",
        "scale": {
          "50":  "#F5F3FF",
          "100": "#EDE9FE",
          "200": "#DDD6FE",
          "300": "#C4B5FD",
          "400": "#A78BFA",
          "500": "#8B5CF6",
          "600": "#7C3AED",
          "700": "#6D28D9",
          "800": "#5B21B6",
          "900": "#4C1D95",
          "950": "#2E1065"
        },
        "usage": {
          "activeNavLabel": "#8B5CF6",
          "activeNavIcon": "#8B5CF6",
          "primaryCtaSurface": "#0F0F12",
          "primaryCtaText": "#FFFFFF",
          "linkText": "#7C3AED",
          "linkHoverText": "#6D28D9",
          "selectedDateBackground": "#7C3AED",
          "selectedDateText": "#FFFFFF",
          "barChartFill": "#7C3AED",
          "successBadgeText": "#5B21B6",
          "successBadgeSurface": "#EDE9FE",
          "statusDotLive": "#8B5CF6"
        }
      },
      "secondary": {
        "base": "#EC4899",
        "scale": {
          "50":  "#FDF2F8",
          "100": "#FCE7F3",
          "200": "#FBCFE8",
          "300": "#F9A8D4",
          "400": "#F472B6",
          "500": "#EC4899",
          "600": "#DB2777",
          "700": "#BE185D",
          "800": "#9D174D",
          "900": "#831843",
          "950": "#500724"
        },
        "usage": {
          "secondaryAccent": "#EC4899",
          "highlightTag": "#FBCFE8",
          "highlightTagText": "#9D174D",
          "decorativeUnderline": "#EC4899",
          "trialingBadgeSurface": "#FCE7F3",
          "trialingBadgeText": "#9D174D"
        }
      },
      "neutral": {
        "scale": {
          "0":   "#FFFFFF",
          "50":  "#FAFAFA",
          "100": "#F5F5F5",
          "200": "#EAEAEA",
          "300": "#D4D4D4",
          "400": "#A3A3A3",
          "500": "#737373",
          "600": "#525252",
          "700": "#404040",
          "800": "#262626",
          "900": "#171717",
          "950": "#0A0A0A"
        },
        "usage": {
          "pageBackground": "#FFFFFF",
          "sidebarBackground": "#FAFAFA",
          "cardSurface": "#FFFFFF",
          "subtleSurface": "#F5F5F5",
          "divider": "#EAEAEA",
          "border": "#EAEAEA",
          "borderStrong": "#D4D4D4",
          "textPrimary": "#0A0A0A",
          "textSecondary": "#525252",
          "textTertiary": "#A3A3A3",
          "textPlaceholder": "#A3A3A3",
          "textInverse": "#FFFFFF",
          "iconDefault": "#525252",
          "iconMuted": "#A3A3A3"
        }
      },
      "status": {
        "success": {
          "surface": "#EDE9FE",
          "text": "#5B21B6",
          "icon": "#7C3AED",
          "note": "Mintlify 원본은 그린이지만, 커스텀 팔레트 통일을 위해 primary 톤으로 통합"
        },
        "warning": {
          "surface": "#FEF3C7",
          "text": "#92400E",
          "icon": "#D97706"
        },
        "danger": {
          "surface": "#FEE2E2",
          "text": "#991B1B",
          "icon": "#DC2626",
          "buttonSurface": "#DC2626",
          "buttonText": "#FFFFFF"
        },
        "info": {
          "surface": "#FCE7F3",
          "text": "#9D174D",
          "icon": "#EC4899"
        }
      }
    },

    "typography": {
      "fontFamily": {
        "primary": "'Pretendard', 'Pretendard Variable', -apple-system, BlinkMacSystemFont, system-ui, sans-serif",
        "mono": "'Pretendard', 'JetBrains Mono', 'SF Mono', Menlo, monospace",
        "note": "Pretendard 단일 패밀리로 통일. 코드 블록은 추후 별도 모노스페이스 지정 가능"
      },
      "fontWeight": {
        "regular": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      },
      "scale": {
        "displayLarge":  { "size": "32px", "lineHeight": "40px", "weight": 700, "letterSpacing": "-0.02em", "usage": "페이지 메인 타이틀 (예: Good morning, hyunsoo)" },
        "displayMedium": { "size": "24px", "lineHeight": "32px", "weight": 700, "letterSpacing": "-0.01em", "usage": "섹션 타이틀" },
        "headingLarge":  { "size": "20px", "lineHeight": "28px", "weight": 600, "usage": "카드/패널 제목" },
        "headingMedium": { "size": "16px", "lineHeight": "24px", "weight": 600, "usage": "메뉴 그룹 헤더, 서브 섹션" },
        "headingSmall":  { "size": "14px", "lineHeight": "20px", "weight": 600, "usage": "테이블 컬럼 헤더, 사이드바 카테고리" },
        "bodyLarge":     { "size": "16px", "lineHeight": "24px", "weight": 400, "usage": "본문 기본" },
        "bodyMedium":    { "size": "14px", "lineHeight": "20px", "weight": 400, "usage": "사이드바 메뉴 라벨, 일반 UI 텍스트" },
        "bodySmall":     { "size": "13px", "lineHeight": "18px", "weight": 400, "usage": "보조 정보, 설명문" },
        "caption":       { "size": "12px", "lineHeight": "16px", "weight": 400, "usage": "메타 정보, 타임스탬프" },
        "label":         { "size": "12px", "lineHeight": "16px", "weight": 500, "letterSpacing": "0.04em", "textTransform": "uppercase", "usage": "Agents, Workspace 같은 카테고리 라벨" },
        "metric":        { "size": "32px", "lineHeight": "40px", "weight": 600, "usage": "Visitors 6, Views 9 같은 지표 숫자" },
        "buttonLabel":   { "size": "14px", "lineHeight": "20px", "weight": 500, "usage": "버튼 텍스트" }
      }
    },

    "spacing": {
      "scale": {
        "0":  "0px",
        "1":  "4px",
        "2":  "8px",
        "3":  "12px",
        "4":  "16px",
        "5":  "20px",
        "6":  "24px",
        "8":  "32px",
        "10": "40px",
        "12": "48px",
        "16": "64px",
        "20": "80px"
      },
      "componentPadding": {
        "buttonHorizontal": "16px",
        "buttonVertical": "10px",
        "inputHorizontal": "12px",
        "inputVertical": "10px",
        "cardInner": "24px",
        "panelInner": "20px",
        "sidebarItem": "10px 12px",
        "tableCell": "12px 16px"
      }
    },

    "borderRadius": {
      "none": "0px",
      "sm": "6px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "pill": "9999px",
      "usage": {
        "buttonPrimary": "9999px",
        "buttonSecondary": "9999px",
        "input": "8px",
        "card": "12px",
        "panel": "12px",
        "badge": "9999px",
        "avatar": "9999px",
        "tooltip": "8px"
      }
    },

    "elevation": {
      "shadow": {
        "none":   "none",
        "xs":     "0 1px 2px rgba(10, 10, 10, 0.04)",
        "sm":     "0 1px 3px rgba(10, 10, 10, 0.06), 0 1px 2px rgba(10, 10, 10, 0.04)",
        "md":     "0 4px 8px rgba(10, 10, 10, 0.06), 0 2px 4px rgba(10, 10, 10, 0.04)",
        "lg":     "0 12px 24px rgba(10, 10, 10, 0.08), 0 4px 8px rgba(10, 10, 10, 0.04)",
        "xl":     "0 24px 48px rgba(10, 10, 10, 0.12)",
        "focus":  "0 0 0 3px rgba(139, 92, 246, 0.2)",
        "focusPink": "0 0 0 3px rgba(236, 72, 153, 0.2)"
      },
      "usage": {
        "card": "sm",
        "popover": "lg",
        "modal": "xl",
        "dropdown": "md",
        "tooltipBubble": "md"
      }
    },

    "componentStyles": {
      "sidebar": {
        "surfaceColor": "#FAFAFA",
        "borderRight": "1px solid #EAEAEA",
        "width": "240px",
        "logo": {
          "containerSize": "32px",
          "borderRadius": "9999px"
        },
        "navItem": {
          "default": {
            "textColor": "#525252",
            "iconColor": "#525252",
            "surfaceColor": "transparent",
            "padding": "10px 12px",
            "borderRadius": "8px",
            "fontSize": "14px",
            "fontWeight": 400
          },
          "hover": {
            "surfaceColor": "#F5F5F5",
            "textColor": "#0A0A0A"
          },
          "active": {
            "textColor": "#8B5CF6",
            "iconColor": "#8B5CF6",
            "surfaceColor": "transparent",
            "fontWeight": 500
          }
        },
        "categoryLabel": {
          "fontSize": "12px",
          "fontWeight": 500,
          "textColor": "#A3A3A3",
          "textTransform": "none",
          "padding": "16px 12px 8px"
        },
        "newBadge": {
          "surfaceColor": "#EDE9FE",
          "textColor": "#5B21B6",
          "fontSize": "11px",
          "fontWeight": 500,
          "padding": "2px 8px",
          "borderRadius": "9999px"
        }
      },

      "topBar": {
        "height": "56px",
        "borderBottom": "1px solid #EAEAEA",
        "search": {
          "surfaceColor": "#FFFFFF",
          "border": "1px solid #EAEAEA",
          "borderRadius": "8px",
          "placeholderColor": "#A3A3A3",
          "iconColor": "#A3A3A3",
          "shortcutBadge": {
            "surfaceColor": "#F5F5F5",
            "textColor": "#525252",
            "fontSize": "12px",
            "borderRadius": "4px",
            "padding": "2px 6px"
          }
        },
        "iconButton": {
          "size": "36px",
          "iconColor": "#525252",
          "hoverSurface": "#F5F5F5",
          "borderRadius": "8px"
        }
      },

      "panelContainers": {
        "surfaceColor": "#FFFFFF",
        "borderTreatment": "1px solid #EAEAEA",
        "borderRadius": "12px",
        "elevationShadow": "0 1px 3px rgba(10, 10, 10, 0.06)",
        "innerPadding": "20px",
        "highlightPanel": {
          "surfaceColor": "#FAFAFA",
          "borderTreatment": "1px solid #EAEAEA",
          "iconColor": "#8B5CF6"
        }
      },

      "modal": {
        "overlay": {
          "surfaceColor": "rgba(10, 10, 10, 0.55)",
          "backdropBlur": "4px",
          "paddingX": "16px",
          "paddingY": "32px"
        },
        "shell": {
          "maxWidth": "560px",
          "surfaceColor": "#FFFFFF",
          "border": "1px solid rgba(255,255,255,0.7)",
          "borderRadius": "36px",
          "padding": {
            "mobile": "28px 28px 36px",
            "desktop": "32px 40px 44px"
          },
          "shadow": "0 30px 100px rgba(15, 23, 42, 0.24)",
          "topGlow": "radial-gradient(circle_at_top, rgba(124, 140, 255, 0.14), transparent 68%)"
        },
        "content": {
          "maxWidth": "420px",
          "alignment": "center"
        },
        "header": {
          "eyebrow": {
            "fontSize": "11px",
            "fontWeight": 600,
            "letterSpacing": "0.24em",
            "textTransform": "uppercase",
            "textColor": "#A3A3A3"
          },
          "title": {
            "fontSize": {
              "mobile": "30px",
              "desktop": "32px"
            },
            "lineHeight": {
              "mobile": "38px",
              "desktop": "40px"
            },
            "fontWeight": 600,
            "letterSpacing": "-0.02em",
            "textColor": "#0A0A0A"
          },
          "description": {
            "fontSize": {
              "mobile": "15px",
              "desktop": "16px"
            },
            "lineHeight": "28px",
            "textColor": "#525252"
          }
        },
        "badge": {
          "size": "64px",
          "borderRadius": "24px"
        },
        "actions": {
          "primaryPill": {
            "surfaceColor": "#0A0A0A",
            "textColor": "#FFFFFF",
            "borderRadius": "9999px",
            "padding": "12px 24px",
            "fontSize": "14px",
            "fontWeight": 600,
            "hoverSurface": "#262626"
          },
          "authButton": {
            "surfaceColor": "#FAFAFA",
            "textColor": "#0A0A0A",
            "border": "1px solid #EAEAEA",
            "borderRadius": "20px",
            "padding": "20px 24px",
            "fontSize": {
              "mobile": "18px",
              "desktop": "19px"
            },
            "fontWeight": 600,
            "hoverBorder": "#DDD6FE",
            "hoverSurface": "#FFFFFF",
            "hoverShadow": "0 12px 30px rgba(15, 23, 42, 0.08)"
          }
        },
        "interaction": {
          "closeOnOverlayClick": true,
          "closeIconDefault": false,
          "note": "모달 닫기 규칙은 기본적으로 배경 클릭 우선. 별도 X 버튼은 명시적으로 필요한 경우에만 사용"
        }
      },

      "metricCard": {
        "surfaceColor": "#FFFFFF",
        "borderTreatment": "1px solid #EAEAEA",
        "borderRadius": "12px",
        "padding": "20px",
        "labelText": {
          "color": "#525252",
          "fontSize": "14px",
          "fontWeight": 400
        },
        "valueText": {
          "color": "#0A0A0A",
          "fontSize": "32px",
          "fontWeight": 600,
          "lineHeight": "40px"
        },
        "deltaIndicator": {
          "neutralColor": "#A3A3A3",
          "positiveColor": "#7C3AED",
          "negativeColor": "#DC2626"
        }
      },

      "actionControls": {
        "primaryButton": {
          "surfaceColor": "#0A0A0A",
          "textColor": "#FFFFFF",
          "borderRadius": "9999px",
          "padding": "10px 20px",
          "fontSize": "14px",
          "fontWeight": 500,
          "interactionStates": {
            "hoverSurface": "#262626",
            "activeSurface": "#404040",
            "disabledSurface": "#D4D4D4",
            "disabledText": "#A3A3A3",
            "focusRing": "0 0 0 3px rgba(139, 92, 246, 0.3)"
          }
        },
        "secondaryButton": {
          "surfaceColor": "#FFFFFF",
          "textColor": "#0A0A0A",
          "border": "1px solid #EAEAEA",
          "borderRadius": "9999px",
          "padding": "10px 20px",
          "fontSize": "14px",
          "fontWeight": 500,
          "interactionStates": {
            "hoverSurface": "#FAFAFA",
            "hoverBorder": "#D4D4D4",
            "activeSurface": "#F5F5F5"
          }
        },
        "ghostButton": {
          "surfaceColor": "transparent",
          "textColor": "#525252",
          "borderRadius": "8px",
          "padding": "8px 12px",
          "interactionStates": {
            "hoverSurface": "#F5F5F5",
            "hoverText": "#0A0A0A"
          }
        },
        "dangerButton": {
          "surfaceColor": "#DC2626",
          "textColor": "#FFFFFF",
          "borderRadius": "9999px",
          "padding": "10px 20px",
          "fontWeight": 500,
          "interactionStates": {
            "hoverSurface": "#B91C1C"
          }
        },
        "linkText": {
          "color": "#7C3AED",
          "fontWeight": 500,
          "textDecoration": "none",
          "interactionStates": {
            "hoverColor": "#6D28D9",
            "hoverDecoration": "underline"
          }
        }
      },

      "formInput": {
        "surfaceColor": "#FFFFFF",
        "border": "1px solid #EAEAEA",
        "borderRadius": "8px",
        "padding": "10px 12px",
        "fontSize": "14px",
        "textColor": "#0A0A0A",
        "placeholderColor": "#A3A3A3",
        "iconColor": "#A3A3A3",
        "interactionStates": {
          "hoverBorder": "#D4D4D4",
          "focusBorder": "#8B5CF6",
          "focusRing": "0 0 0 3px rgba(139, 92, 246, 0.15)",
          "errorBorder": "#DC2626",
          "errorRing": "0 0 0 3px rgba(220, 38, 38, 0.15)",
          "disabledSurface": "#FAFAFA",
          "disabledText": "#A3A3A3"
        }
      },

      "toggle": {
        "track": {
          "off": "#D4D4D4",
          "on": "#8B5CF6",
          "width": "36px",
          "height": "20px",
          "borderRadius": "9999px"
        },
        "thumb": {
          "surfaceColor": "#FFFFFF",
          "size": "16px",
          "shadow": "0 1px 2px rgba(10, 10, 10, 0.2)"
        }
      },

      "badge": {
        "default": {
          "surfaceColor": "#F5F5F5",
          "textColor": "#525252"
        },
        "success": {
          "surfaceColor": "#EDE9FE",
          "textColor": "#5B21B6",
          "iconColor": "#7C3AED",
          "note": "Mintlify의 그린 Successful 뱃지를 보라 톤으로 변환"
        },
        "info": {
          "surfaceColor": "#FCE7F3",
          "textColor": "#9D174D"
        },
        "warning": {
          "surfaceColor": "#FEF3C7",
          "textColor": "#92400E"
        },
        "danger": {
          "surfaceColor": "#FEE2E2",
          "textColor": "#991B1B"
        },
        "trialing": {
          "surfaceColor": "#EDE9FE",
          "textColor": "#5B21B6"
        },
        "shape": {
          "borderRadius": "9999px",
          "padding": "2px 10px",
          "fontSize": "12px",
          "fontWeight": 500
        }
      },

      "table": {
        "headerRow": {
          "surfaceColor": "transparent",
          "textColor": "#525252",
          "fontSize": "13px",
          "fontWeight": 500,
          "borderBottom": "1px solid #EAEAEA",
          "padding": "12px 16px"
        },
        "bodyRow": {
          "surfaceColor": "#FFFFFF",
          "borderBottom": "1px solid #F5F5F5",
          "padding": "16px",
          "interactionStates": {
            "hoverSurface": "#FAFAFA"
          }
        },
        "cellText": {
          "primaryColor": "#0A0A0A",
          "secondaryColor": "#525252",
          "fontSize": "14px"
        }
      },

      "datePicker": {
        "trigger": {
          "border": "1px solid #EAEAEA",
          "borderRadius": "9999px",
          "padding": "8px 16px",
          "iconColor": "#525252"
        },
        "popover": {
          "surfaceColor": "#FFFFFF",
          "border": "1px solid #EAEAEA",
          "borderRadius": "12px",
          "shadow": "0 12px 24px rgba(10, 10, 10, 0.08)",
          "padding": "16px"
        },
        "presets": {
          "textColor": "#525252",
          "hoverSurface": "#F5F5F5",
          "borderRadius": "6px",
          "padding": "8px 12px"
        },
        "calendarCell": {
          "default": {
            "size": "36px",
            "borderRadius": "8px",
            "textColor": "#0A0A0A"
          },
          "hover": {
            "surfaceColor": "#F5F5F5"
          },
          "selected": {
            "surfaceColor": "#7C3AED",
            "textColor": "#FFFFFF"
          },
          "rangeMiddle": {
            "surfaceColor": "#EDE9FE",
            "textColor": "#5B21B6"
          },
          "today": {
            "borderColor": "#8B5CF6"
          },
          "outsideMonth": {
            "textColor": "#A3A3A3"
          }
        }
      },

      "chart": {
        "barFillPrimary": "#7C3AED",
        "barFillSecondary": "#EC4899",
        "axisLabelColor": "#A3A3A3",
        "gridLineColor": "#F5F5F5",
        "tooltipSurface": "#0A0A0A",
        "tooltipText": "#FFFFFF"
      },

      "feedbackWidget": {
        "surfaceColor": "#FFFFFF",
        "border": "1px solid #EAEAEA",
        "borderRadius": "12px",
        "shadow": "0 12px 24px rgba(10, 10, 10, 0.08)",
        "padding": "16px",
        "ratingButton": {
          "default": {
            "surfaceColor": "#FFFFFF",
            "border": "1px solid #EAEAEA",
            "textColor": "#0A0A0A",
            "size": "40px",
            "borderRadius": "8px"
          },
          "hover": {
            "surfaceColor": "#F5F5F5"
          },
          "selected": {
            "surfaceColor": "#8B5CF6",
            "textColor": "#FFFFFF",
            "border": "1px solid #8B5CF6"
          }
        }
      },

      "alertBanner": {
        "surfaceColor": "#FAFAFA",
        "border": "1px solid #EAEAEA",
        "borderRadius": "12px",
        "padding": "16px 20px",
        "iconColor": "#7C3AED",
        "titleColor": "#0A0A0A",
        "bodyColor": "#525252",
        "closeIconColor": "#A3A3A3"
      },

      "pricingCard": {
        "surfaceColor": "#FFFFFF",
        "border": "1px solid #EAEAEA",
        "borderRadius": "16px",
        "padding": "32px",
        "popularVariant": {
          "border": "1.5px solid #8B5CF6",
          "shadow": "0 12px 24px rgba(139, 92, 246, 0.12)"
        },
        "popularBadge": {
          "surfaceColor": "#8B5CF6",
          "textColor": "#FFFFFF"
        }
      }
    },

    "iconography": {
      "defaultStyle": "outlined",
      "strokeWidth": "1.5px",
      "size": {
        "sm": "16px",
        "md": "20px",
        "lg": "24px"
      },
      "colorRules": {
        "navigationDefault": "#525252",
        "navigationActive": "#8B5CF6",
        "decorativeIllustration": "#EC4899",
        "successCheck": "#7C3AED",
        "destructive": "#DC2626"
      }
    },

    "qualityAssurance": {
      "doNot": [
        "Apply purple gradient backgrounds to icons (icons stay flat-colored)",
        "Use pink for primary CTAs — pink is for accents only",
        "Use Pretendard light weights below 400 — text becomes hard to read on white",
        "Apply card shadow to inner content elements",
        "Mix the original Mintlify green with this palette anywhere"
      ],
      "doEnsure": [
        "Pretendard is loaded before any UI renders to avoid font-flash",
        "Active nav items use #8B5CF6 text/icon, NOT a filled background",
        "All status badges follow the pill (9999px) shape consistently",
        "Focus rings use the primary purple at 0.15–0.30 alpha",
        "Pink (#EC4899) only appears as: decorative underline, info badge, secondary chart color"
      ],
      "accessibility": {
        "primaryOnWhite": {
          "color": "#7C3AED",
